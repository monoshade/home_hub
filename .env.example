# Copy to .env and adjust as needed.

# --- Runtime context (shared by backend + frontend) ---
# APP_DB:  prod | demo | test   (which database to connect to)
# APP_ENV: prod | demo          (which environment to run as)
# Default profile is demo; for the prod profile set both: APP_DB=prod APP_ENV=prod
APP_DB=demo
APP_ENV=demo

# --- PostgreSQL ---
POSTGRES_USER=home_hub
POSTGRES_PASSWORD=home_hub
POSTGRES_DB=demo          # the demo database (db context: demo)
POSTGRES_PROD_DB=prod     # the prod database (db context: prod)
POSTGRES_TEST_DB=test     # the empty test database (db context: test)
POSTGRES_PORT=5432

# --- Backend (PHP) ---
BACKEND_PORT=8080
# How the backend reaches Postgres. Default works when db is started via compose
# (it publishes POSTGRES_PORT on the host); override for an external database.
DB_HOST=host.docker.internal
DB_PORT=5432

# --- Frontend (React) ---
FRONTEND_PORT=5173
# Where the browser reaches the backend. Defaults to localhost:$BACKEND_PORT.
VITE_API_URL=http://localhost:8080
